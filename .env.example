# Copy to .env and fill in real values before running `docker compose up`.

# Shared JWT signing secret (users-service issues, other services verify).
JWT_SECRET_KEY=change-me-to-a-long-random-string

# Anthropic API key for fruit-assistant-service. If left empty, the service
# falls back to a canned response so the rest of the stack still works.
ANTHROPIC_API_KEY=
